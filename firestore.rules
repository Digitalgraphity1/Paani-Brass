rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: leads
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - mobile: string (required, 10-15 chars)
    //   - inquiry: string (required, 1-100 chars)
    //   - notes: string (optional, 0-500 chars)
    //   - createdAt: timestamp (required)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['mobile', 'createdAt']) &&
             data.mobile is string && data.mobile.size() >= 10 && data.mobile.size() <= 15 &&
             ( !('name' in data) || (data.name is string && data.name.size() <= 100) ) &&
             ( !('inquiry' in data) || (data.inquiry is string && data.inquiry.size() <= 100) ) &&
             ( !('staffName' in data) || (data.staffName is string && data.staffName.size() <= 100) ) &&
             ( !('city' in data) || (data.city is string && data.city.size() <= 100) ) &&
             ( !('notes' in data) || (data.notes is string && data.notes.size() <= 500) ) &&
             ( !('cardImage' in data) || (data.cardImage is string && data.cardImage.size() <= 200000) ) &&
             data.createdAt is timestamp;
    }

    match /leads/{leadId} {
      // Exhibition mode: Allow public access for easy use without login
      allow read, list: if true;
      allow create: if isValidLead(request.resource.data);
      allow update, delete: if true;
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
